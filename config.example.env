# Alerts remain local unless live mode is explicitly enabled.
GESTURE_BRIDGE_LIVE_ALERTS=0
GESTURE_BRIDGE_ALERT_WEBHOOK=https://your-caregiver-service.example/alert
GESTURE_BRIDGE_LOCATION=Project Lab, Building A
GESTURE_BRIDGE_BUZZER_PIN=17
GESTURE_BRIDGE_ALERT_RETRIES=3
GESTURE_BRIDGE_CAMERA_INDEX=0

# Set to 1 when gpsd is connected to a supported USB/UART GPS receiver.
GESTURE_BRIDGE_GPSD=0

# Optional direct SMS or WhatsApp delivery through Twilio.
# For WhatsApp, use whatsapp:+countrycode... in both phone fields.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
GESTURE_BRIDGE_CAREGIVER_TO=
