# Alerts remain local unless live mode is explicitly enabled.
GESTURE_BRIDGE_LIVE_ALERTS=0
GESTURE_BRIDGE_ALERT_WEBHOOK=
GESTURE_BRIDGE_NTFY_URL=
GESTURE_BRIDGE_NTFY_TOKEN=
GESTURE_BRIDGE_CONTACT_NAME=Doctor or caregiver
GESTURE_BRIDGE_LOCATION=Project Lab, Building A
GESTURE_BRIDGE_BUZZER_PIN=17
GESTURE_BRIDGE_ALERT_RETRIES=3
GESTURE_BRIDGE_ALERT_COUNTDOWN_SECONDS=5
# Safe defaults: only the confirmed closed-fist Emergency sends a notification.
GESTURE_BRIDGE_ENABLE_SILENT_SOS=0
GESTURE_BRIDGE_ENABLE_DISTRESS_ESCALATION=0
# -1 scans indices 0-5 and selects the first webcam that returns frames.
GESTURE_BRIDGE_CAMERA_INDEX=-1
# Use 1 when running as a background service or entirely through SSH.
GESTURE_BRIDGE_HEADLESS=0
GESTURE_BRIDGE_DISPLAY_WIDTH=1280
GESTURE_BRIDGE_DISPLAY_HEIGHT=720
# Graphical camera capture stays high-resolution; inference is downscaled separately.
GESTURE_BRIDGE_CAPTURE_WIDTH=1280
GESTURE_BRIDGE_CAPTURE_HEIGHT=720
# MediaPipe analyzes this smaller frame, then the camera is scaled for display.
GESTURE_BRIDGE_ANALYSIS_WIDTH=640
GESTURE_BRIDGE_ANALYSIS_HEIGHT=360
GESTURE_BRIDGE_TEXT_RENDERER=opencv

# Set to 1 when gpsd is connected to a supported USB/UART GPS receiver.
GESTURE_BRIDGE_GPSD=0

# Optional direct SMS or WhatsApp delivery through Twilio.
# For WhatsApp, use whatsapp:+countrycode... in both phone fields.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
GESTURE_BRIDGE_CAREGIVER_TO=
